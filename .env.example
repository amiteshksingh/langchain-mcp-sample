# LLM provider switch: huggingface, github, or ollama
LLM_PROVIDER=huggingface

# Hugging Face OpenAI-compatible endpoint settings
HF_API_KEY=replace_with_token
HF_BASE_URL=https://router.huggingface.co/v1
HF_MODEL=Qwen/Qwen2.5-7B-Instruct

# GitHub Models OpenAI-compatible endpoint settings
GITHUB_TOKEN=replace_with_token
GITHUB_BASE_URL=https://models.github.ai/inference
GITHUB_MODEL=meta/Llama-4-Scout-17B-16E-Instruct

# Ollama settings
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b-instruct

# Shared settings
LLM_TEMPERATURE=0.2
LLM_TIMEOUT_SECONDS=45
MCP_SERVER_URL=http://127.0.0.1:8000/mcp

# RAG settings (sensitive file -> vector DB)
RAG_ENABLED=true
RAG_SOURCE_FILE=data/sensitive.txt
RAG_DB_DIR=data/vector_db
RAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAG_TOP_K=3
RAG_CHUNK_SIZE=700
RAG_CHUNK_OVERLAP=100
