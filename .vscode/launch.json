{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: LangChain demo",
      "type": "debugpy",
      "request": "launch",
      "module": "app.main",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      },
      "envFile": "${workspaceFolder}/.env"
    },
    {
      "name": "Python: MCP server",
      "type": "debugpy",
      "request": "launch",
      "module": "mcp_server.server",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      },
      "envFile": "${workspaceFolder}/.env"
    }
  ]
}
